<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  Auto-Tobe-Agent launchd 배치 설정 (Tier 2: Fix 배치)
  사람 비활성 시간(새벽)에 실행하여 Agent-Human 충돌을 방지합니다.
    - 01:00 메인 수정 (QA Agent 전날 22시 점검 결과 처리)
    - 05:00 보충 수정 (재시도 + 잔여 이슈 처리)

  설치:
    1. 이 파일의 경로를 운영 환경에 맞게 수정하세요 (AGENT_HOME, HOME 등)
    2. cp scripts/com.bluevlad.auto-tobe-agent.plist ~/Library/LaunchAgents/
    3. launchctl load ~/Library/LaunchAgents/com.bluevlad.auto-tobe-agent.plist

  주의: 경로에 실제 사용자명/서버 정보를 포함하지 않도록 local.json에서 오버라이드하세요.
  참조: AGENT_CONFLICT_PREVENTION_GUIDE.md §2.1 (시간대 분리 전략)
-->
<dict>
    <key>Label</key>
    <string>com.bluevlad.auto-tobe-agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${AGENT_HOME}/scripts/run-batch.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Hour</key>
            <integer>1</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>5</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
    </array>

    <key>WorkingDirectory</key>
    <string>${AGENT_HOME}</string>

    <key>StandardOutPath</key>
    <string>${AGENT_HOME}/logs/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>${AGENT_HOME}/logs/launchd-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>AbandonProcessGroup</key>
    <false/>
</dict>
</plist>
